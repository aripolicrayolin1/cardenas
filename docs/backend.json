
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del agricultor.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "location": { "type": "string" },
        "cropType": { "type": "string" }
      },
      "required": ["email"]
    },
    "Farm": {
      "title": "Finca",
      "description": "Datos de un terreno monitoreado.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "crop": { "type": "string" },
        "area": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string" },
        "humidity": { "type": "string" },
        "temp": { "type": "string" },
        "lastUpdate": { "type": "string" }
      }
    },
    "CommunityAlert": {
      "title": "Alerta Comunitaria",
      "description": "Reporte de plaga o enfermedad compartido por la comunidad.",
      "type": "object",
      "properties": {
        "region": { "type": "string" },
        "crop": { "type": "string" },
        "problem": { "type": "string" },
        "severity": { "type": "string" },
        "distance": { "type": "string" },
        "date": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos de perfil del usuario"
    },
    "/users/{userId}/farms/{farmId}": {
      "schema": "Farm",
      "description": "Fincas registradas por el usuario"
    },
    "/community_alerts/{alertId}": {
      "schema": "CommunityAlert",
      "description": "Alertas globales compartidas por los agricultores"
    }
  }
}
