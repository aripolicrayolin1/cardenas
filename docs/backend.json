
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información detallada del agricultor vinculada a su cuenta de AgroTech Hidalgo.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "location": { "type": "string" },
        "cropType": { "type": "string" }
      },
      "required": ["email"]
    },
    "Farm": {
      "title": "Finca Agrícola",
      "description": "Datos de un terreno monitoreado y gestionado por el usuario en la región.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "crop": { "type": "string" },
        "area": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string" },
        "humidity": { "type": "string" },
        "temp": { "type": "string" },
        "lastUpdate": { "type": "string" }
      },
      "required": ["name", "userId"]
    },
    "MarketplaceProduct": {
      "title": "Producto de Mercado",
      "description": "Insumos, herramientas o cosechas a la venta en la comunidad.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "sellerName": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "userId"]
    },
    "JobPosting": {
      "title": "Oferta de Empleo",
      "description": "Vacantes para trabajo en el campo o soporte técnico agrícola.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "salary": { "type": "string" },
        "employerName": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "userId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos privados de perfil."
    },
    "/users/{userId}/farms/{farmId}": {
      "schema": "Farm",
      "description": "Fincas del usuario."
    },
    "/marketplace_products/{productId}": {
      "schema": "MarketplaceProduct",
      "description": "Productos compartidos entre apps."
    },
    "/job_postings/{jobId}": {
      "schema": "JobPosting",
      "description": "Empleos compartidos entre apps."
    }
  }
}
